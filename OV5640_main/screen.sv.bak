module screen (
    input  logic        pixel_clk,
    input  logic [9 :0]         x,   
    input  logic [9 :0]         y,
    output logic [15:0] pixel_out
);

    // Размер экрана 640x480 = 307200 пикселей
    localparam int TOTAL_PIXELS = 640 * 480;

    // Память: 16 бит на пиксель
    logic [15:0] mem [0:TOTAL_PIXELS-1];

    // Внутренний сигнал для адреса
    logic [18:0] addr;

    // 1. Комбинационный расчет адреса: addr = (y * 640) + x
    // Мы используем 640, но для оптимизации FPGA иногда лучше 
    // использовать степени двойки (например, 1024), если это допустимо.
    assign addr = (y * 10'd640) + x;

    // Инициализация памяти красным цветом (RGB565: 16'hF800)
    initial begin
        for (int i = 0; i < TOTAL_PIXELS; i++) begin
            mem[i] = 16'hF800; 
        end
    end

    // 2. Синхронное чтение (Block RAM style)
    // Данные появятся на pixel_out ровно на следующем фронте clk после выставления hpos/vpos
    always_ff @(posedge clk) begin
        pixel_out <= mem[addr];
    end

endmodule
